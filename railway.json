{
  "$schema": "https://railway.com/railway.schema.json",
  "services": [
    {
      "name": "backend",
      "root": "backend",
      "build": { "builder": "NIXPACKS" },
      "deploy": {
        "startCommand": "uvicorn app:app --host 0.0.0.0 --port $PORT",
        "numReplicas": 1
      }
    },
    {
      "name": "frontend",
      "root": "frontend",
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm install && npm run build"
      },
      "deploy": {
        "startCommand": "npx serve -s dist -l $PORT"
      }
    }
  ]
}